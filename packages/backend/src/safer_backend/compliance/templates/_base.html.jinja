{#- Shared layout: header, footer, page rules, palette. Specific standards
    extend this via {% extends "_base.html.jinja" %}. -#}
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8" />
<title>{{ title }} — SAFER</title>
<style>
@page {
  size: A4;
  margin: 20mm 16mm 22mm 16mm;
  @bottom-center {
    content: "SAFER Compliance Pack · " counter(page) " / " counter(pages);
    font-family: "Helvetica", "Arial", sans-serif;
    font-size: 9pt;
    color: #6b7280;
  }
}
* { box-sizing: border-box; }
body {
  font-family: "Helvetica", "Arial", sans-serif;
  font-size: 10pt;
  color: #0f172a;
  line-height: 1.45;
  margin: 0;
}
h1 { font-size: 22pt; margin: 0 0 4pt 0; color: #0f172a; }
h2 { font-size: 14pt; margin: 20pt 0 8pt 0; color: #0f172a; padding-bottom: 3pt; border-bottom: 1px solid #e5e7eb; }
h3 { font-size: 11pt; margin: 14pt 0 6pt 0; color: #334155; }
p  { margin: 6pt 0; }
table { width: 100%; border-collapse: collapse; margin: 6pt 0 12pt 0; }
th, td {
  text-align: left;
  padding: 5pt 6pt;
  border-bottom: 1px solid #e5e7eb;
  font-size: 9.5pt;
  vertical-align: top;
}
th { background: #f1f5f9; color: #0f172a; font-weight: 600; }
.mono { font-family: "Menlo", "JetBrains Mono", "Courier New", monospace; font-size: 9pt; }
.muted { color: #64748b; }
.small { font-size: 8.5pt; }
.pill {
  display: inline-block;
  border-radius: 999px;
  padding: 1pt 7pt;
  font-size: 8.5pt;
  font-weight: 600;
  border: 1px solid transparent;
}
.pill-low      { background: #ecfdf5; color: #065f46; border-color: #a7f3d0; }
.pill-medium   { background: #eff6ff; color: #1e3a8a; border-color: #bfdbfe; }
.pill-high     { background: #fffbeb; color: #92400e; border-color: #fde68a; }
.pill-critical { background: #fef2f2; color: #991b1b; border-color: #fecaca; }
.grid { display: grid; gap: 8pt; }
.grid-2 { grid-template-columns: 1fr 1fr; }
.grid-4 { grid-template-columns: repeat(4, 1fr); }
.kpi {
  background: #f8fafc;
  border: 1px solid #e5e7eb;
  border-radius: 4pt;
  padding: 8pt 10pt;
}
.kpi .label { color: #64748b; font-size: 8.5pt; text-transform: uppercase; letter-spacing: 0.3pt; }
.kpi .value { font-size: 18pt; font-weight: 600; margin-top: 2pt; }
.cover {
  border-top: 4pt solid #1e3a8a;
  padding: 6pt 0 14pt 0;
  margin-bottom: 6pt;
}
.brand { color: #1e3a8a; font-weight: 700; letter-spacing: 1pt; font-size: 10pt; text-transform: uppercase; }
.footnote { color: #64748b; font-size: 8.5pt; margin-top: 14pt; border-top: 1px dashed #e5e7eb; padding-top: 6pt; }
</style>
</head>
<body>
<div class="cover">
  <div class="brand">SAFER Compliance Pack</div>
  <h1>{{ title }}</h1>
  <p class="muted small">
    Range: {{ data.range_label }} · Generated {{ data.generated_at.isoformat(timespec="seconds") }} UTC
    · Standard: {{ data.standard.value.upper() }}
  </p>
</div>

<div class="grid grid-4">
  <div class="kpi"><div class="label">Agents</div><div class="value">{{ data.total_agents }}</div></div>
  <div class="kpi"><div class="label">Sessions</div><div class="value">{{ data.total_sessions }}</div></div>
  <div class="kpi"><div class="label">Findings</div><div class="value">{{ data.total_findings }}</div></div>
  <div class="kpi"><div class="label">Blocks</div><div class="value">{{ data.total_blocks }}</div></div>
</div>

{% block content %}{% endblock %}

<p class="footnote">
  Generated by SAFER (Agent Control Plane). Data is derived from local
  event ingestion, the Multi-Persona Judge, the Inspector, and the
  Red-Team Squad. This document is not a substitute for legal review.
</p>
</body>
</html>

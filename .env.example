# Anthropic
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_CACHE_ENABLED=true

# Backend
SAFER_BACKEND_HOST=0.0.0.0
SAFER_BACKEND_PORT=8000
SAFER_DB_PATH=./safer.db
SAFER_LOG_LEVEL=INFO

# SDK defaults
SAFER_API_URL=http://localhost:8000
SAFER_GUARD_MODE=monitor  # monitor | intervene | enforce
SAFER_BATCH_SIZE=50
SAFER_BATCH_INTERVAL_MS=500

# Red-Team
RED_TEAM_MODE=managed  # managed | subagent (fallback)

# Dashboard
VITE_BACKEND_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000

# Cost budget (soft)
BUDGET_USD=500
